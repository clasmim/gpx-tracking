<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="580.0" prefWidth="660.0" stylesheets="@../styles/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.GestionMapasController">

    <!-- ── Cabecera — igual que Historial ── -->
    <top>
        <HBox prefHeight="80.0" styleClass="titulo-modificar" BorderPane.alignment="CENTER">
            <Label text="Gestión de mapas" textFill="WHITE">
                <HBox.margin><Insets left="40.0" top="20.0" /></HBox.margin>
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
        </HBox>
    </top>

    <!-- ── Contenido ── -->
    <center>
        <VBox spacing="12.0">
            <padding><Insets bottom="12.0" left="24.0" right="24.0" top="15.0" /></padding>

            <Label styleClass="subtitulo-pantalla" text="Consulta, añade o elimina mapas del sistema." />

            <!-- Tabla de mapas -->
            <TableView fx:id="tablaMapas" prefHeight="200.0" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNombre" prefWidth="120" text="Nombre" />
                    <TableColumn fx:id="colLatMin" prefWidth="95" text="Lat mín" />
                    <TableColumn fx:id="colLatMax" prefWidth="95" text="Lat máx" />
                    <TableColumn fx:id="colLonMin" prefWidth="95" text="Lon mín" />
                    <TableColumn fx:id="colLonMax" prefWidth="95" text="Lon máx" />
                    <TableColumn fx:id="colImagen" prefWidth="152" text="Imagen" />
                </columns>
            </TableView>

            <!-- Borrar -->
            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnBorrar" onAction="#borrarMapa" style="-fx-font-family: 'Montserrat-SemiBold'; -fx-font-size: 11px;                                -fx-text-fill: #CC4444; -fx-background-color: transparent;                                -fx-border-color: #CC4444; -fx-border-radius: 6;                                -fx-background-radius: 6; -fx-border-width: 1;                                -fx-padding: 4 12 4 12; -fx-cursor: hand;" text="Borrar seleccionado" />
            </HBox>

            <Separator />

            <!-- Título sección añadir -->
            <Label text="Añadir nuevo mapa">
                <font><Font name="System Bold" size="15.0" /></font>
            </Label>

            <!-- Formulario -->
            <GridPane hgap="10.0" vgap="8.0">
                <!-- Nombre -->
                <Label style="-fx-alignment: CENTER-RIGHT;" styleClass="campo-label" text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombre" prefHeight="32" promptText="Nombre del mapa" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="0" />

                <!-- Lat mín | Lat máx -->
                <Label style="-fx-alignment: CENTER-RIGHT;" styleClass="campo-label" text="Lat mínima:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtLatMin" prefHeight="32" promptText="Ej: 39.537940" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Label style="-fx-alignment: CENTER-RIGHT;" styleClass="campo-label" text="Lat máxima:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="txtLatMax" prefHeight="32" promptText="Ej: 39.656456" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <!-- Lon mín | Lon máx -->
                <Label style="-fx-alignment: CENTER-RIGHT;" styleClass="campo-label" text="Lon mínima:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtLonMin" prefHeight="32" promptText="Ej: -0.549316" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Label style="-fx-alignment: CENTER-RIGHT;" styleClass="campo-label" text="Lon máxima:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <TextField fx:id="txtLonMax" prefHeight="32" promptText="Ej: -0.373535" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                <!-- Imagen -->
                <Label style="-fx-alignment: CENTER-RIGHT;" styleClass="campo-label" text="Imagen JPG:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <HBox spacing="8" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="3">
                    <TextField fx:id="txtImagen" editable="false" prefHeight="32" promptText="Selecciona un fichero JPG..." HBox.hgrow="ALWAYS" />
                    <Button onAction="#seleccionarImagen" prefHeight="32" styleClass="boton-secundario" text="Examinar..." />
                </HBox>

                <!-- Mensaje resultado -->
                <Label fx:id="lblMensaje" style="-fx-font-family: 'Montserrat-SemiBold'; -fx-font-size: 11px;" text="" GridPane.columnIndex="0" GridPane.columnSpan="4" GridPane.rowIndex="4" />

                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" maxWidth="90" minWidth="90" />
                    <ColumnConstraints hgrow="ALWAYS" />
                    <ColumnConstraints halignment="RIGHT" maxWidth="90" minWidth="90" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="32" />
                    <RowConstraints minHeight="32" />
                    <RowConstraints minHeight="32" />
                    <RowConstraints minHeight="32" />
                    <RowConstraints minHeight="22" />
                </rowConstraints>
            </GridPane>
        </VBox>
    </center>

    <!-- ── Botones ── -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-background-color: white; -fx-padding: 12 24 16 24;">
            <Button onAction="#cerrar" prefWidth="90.0" styleClass="boton-secundario" text="Cerrar" />
            <Button onAction="#añadirMapa" prefWidth="120.0" styleClass="boton-principal" text="Añadir mapa" />
        </HBox>
    </bottom>

</BorderPane>
